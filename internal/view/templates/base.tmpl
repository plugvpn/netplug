{{define "base.tmpl"}}
<!doctype html>
<html lang="en" class="h-full dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NetPlug UI - {{.Title}}</title>
    <link rel="icon" type="image/png" href="/plug-icon.png" />
    <link rel="stylesheet" href="/assets/app.css" />
    <script src="/assets/htmx.min.js"></script>
    <script src="/assets/lucide.min.js"></script>
    <script src="/assets/chart.umd.min.js"></script>
    <script type="module">
      import QRCode from "/assets/qrcode.esm.js";
      window.QRCode = QRCode;
    </script>
    <style>
      /* Shared panel hues */
      :root {
        --np-panel: #0c111c;
        --np-raised: #141f2e;
      }

      /*
        Dark-only UI; html keeps class "dark" for Tailwind dark: variants.
        Single scrollbar + canvas (no light-mode branch).
      */
      html.dark {
        color-scheme: dark;
        --np-canvas: #010409;
        --np-depth: #080d12;
        --np-field: #121a28;
        --np-muted: #1a2738;
        background-color: var(--np-canvas);
      }
      html.dark * {
        scrollbar-width: thin;
        scrollbar-color: rgba(61, 84, 102, 0.55) var(--np-canvas);
      }
      html.dark *::-webkit-scrollbar { width: 8px; height: 8px; }
      html.dark *::-webkit-scrollbar-track { background: var(--np-canvas); }
      html.dark *::-webkit-scrollbar-thumb { background: rgba(61, 84, 102, 0.45); border-radius: 4px; }
      html.dark *::-webkit-scrollbar-thumb:hover { background: rgba(74, 98, 128, 0.55); }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-color: var(--np-canvas);
        min-height: 100vh;
      }

      /* Prefer our palette over system high-contrast outlines (often bright) on dark pages */
      @media (forced-colors: active) {
        html.dark * {
          forced-color-adjust: none;
        }
      }

      .np-page-loading {
        position: absolute;
        inset: 0;
        z-index: 20;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: rgba(1, 4, 9, 0.72);
        backdrop-filter: blur(6px);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.18s ease, visibility 0.18s;
      }
      .np-page-loading.np-page-loading--visible {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
      }
      @keyframes np-spin {
        to { transform: rotate(360deg); }
      }
      .np-page-loading__ring {
        width: 2rem;
        height: 2rem;
        border: 2px solid rgba(16, 185, 129, 0.2);
        border-top-color: rgb(16, 185, 129);
        border-radius: 9999px;
        animation: np-spin 0.7s linear infinite;
      }
    </style>
    <script>
      function toggleSidebar() {
        var el = document.getElementById('sidebar');
        if (!el) return;
        var collapsed = el.dataset.collapsed === 'true';
        el.dataset.collapsed = collapsed ? 'false' : 'true';
        try {
          var left = el.querySelector('[data-lucide="chevron-left"]');
          var right = el.querySelector('[data-lucide="chevron-right"]');
          if (left && right) {
            left.style.display = collapsed ? '' : 'none';
            right.style.display = collapsed ? 'none' : '';
          }
        } catch (e) {}
        try { document.cookie = "sidebar-collapsed=" + (!collapsed) + "; path=/; max-age=31536000"; } catch (e) {}
      }
      function readCookie(name) {
        try {
          var s = document.cookie || '';
          if (!s) return '';
          var parts = s.split('; ');
          for (var i = 0; i < parts.length; i++) {
            var p = parts[i];
            var eq = p.indexOf('=');
            if (eq < 0) continue;
            var k = '';
            var v = '';
            try { k = decodeURIComponent(p.slice(0, eq)); } catch (e) { k = p.slice(0, eq); }
            if (k !== name) continue;
            try { v = decodeURIComponent(p.slice(eq + 1)); } catch (e) { v = p.slice(eq + 1); }
            return v;
          }
          return '';
        } catch (e) { return ''; }
      }
      document.addEventListener('DOMContentLoaded', function () {
        var el = document.getElementById('sidebar');
        if (!el) return;
        var v = readCookie('sidebar-collapsed');
        if (v === 'true') el.dataset.collapsed = 'true';
        try {
          var left = el.querySelector('[data-lucide="chevron-left"]');
          var right = el.querySelector('[data-lucide="chevron-right"]');
          if (left && right) {
            left.style.display = (v === 'true') ? 'none' : '';
            right.style.display = (v === 'true') ? '' : 'none';
          }
        } catch (e) {}
        try { lucide.createIcons(); } catch (e) {}
        try { initBandwidthChart(); } catch (e) {}
        try { syncShellNav(); } catch (e) {}
      });

      window.addEventListener('popstate', function () {
        try { syncShellNav(); } catch (e) {}
      });

      document.addEventListener('htmx:afterSwap', function (evt) {
        try { lucide.createIcons(); } catch (e) {}
        try { initBandwidthChart(); } catch (e) {}
        try {
          if (evt.detail && evt.detail.target && evt.detail.target.id === 'np-main') {
            setPageLoading(false);
            var title = evt.detail.xhr && evt.detail.xhr.getResponseHeader('HX-Title');
            if (title) document.title = title;
          }
        } catch (e) {}
      });

      document.addEventListener('htmx:afterSettle', function () {
        try { syncShellNav(); } catch (e) {}
      });

      function syncShellNav() {
        var path = window.location.pathname || '';
        document.querySelectorAll('#sidebar a.np-spa-link').forEach(function (a) {
          var href = a.getAttribute('href');
          if (!href) return;
          var on = href === path || (href !== '/ui' && path.startsWith(href + '/'));
          a.classList.toggle('np-active', on);
        });
      }

      function npMainSwapTarget(detail) {
        if (!detail) return false;
        if (detail.target && detail.target.id === 'np-main') return true;
        var elt = detail.elt;
        if (!elt) return false;
        var raw = elt.getAttribute && elt.getAttribute('hx-target');
        if (raw && raw.trim() === '#np-main') return true;
        if (window.htmx && typeof htmx.getTarget === 'function') {
          try {
            var t = htmx.getTarget(elt);
            if (t && t.id === 'np-main') return true;
          } catch (e) {}
        }
        return false;
      }

      function setPageLoading(on) {
        var el = document.getElementById('np-page-loading');
        if (!el) return;
        el.classList.toggle('np-page-loading--visible', !!on);
        try {
          el.setAttribute('aria-busy', on ? 'true' : 'false');
          el.setAttribute('aria-hidden', on ? 'false' : 'true');
        } catch (e) {}
      }

      document.addEventListener('htmx:beforeRequest', function (evt) {
        if (npMainSwapTarget(evt.detail)) setPageLoading(true);
      });
      document.addEventListener('htmx:responseError', function (evt) {
        if (npMainSwapTarget(evt.detail)) setPageLoading(false);
      });
      document.addEventListener('htmx:sendError', function (evt) {
        if (npMainSwapTarget(evt.detail)) setPageLoading(false);
      });

      var __bwChart = null;
      async function initBandwidthChart() {
        var canvas = document.getElementById('bandwidth-chart');
        if (!canvas || !window.Chart) return;
        var url = canvas.getAttribute('data-url');
        if (!url) return;

        // Ensure canvas has a height so Chart.js can render inside the card.
        if (!canvas.style.height) canvas.style.height = '256px';
        if (!canvas.style.width) canvas.style.width = '100%';

        var res = await fetch(url, { credentials: 'same-origin' });
        var history = [];
        if (res.ok) {
          try {
            var json = await res.json();
            history = (json && json.history) ? json.history : [];
          } catch (e) {
            history = [];
          }
        }
        if (!Array.isArray(history)) history = [];

        // Always render something, even if the API has no rows yet.
        var labels = history.length
          ? history.map(function (p) { return p.day ? String(p.day) : ''; })
          : Array.from({length: 31}, function(_, i) { return String(i + 1); });
        var download = history.length
          ? history.map(function (p) { return p.downloadTotal || 0; })
          : Array.from({length: 31}, function() { return 0; });
        var upload = history.length
          ? history.map(function (p) { return p.uploadTotal || 0; })
          : Array.from({length: 31}, function() { return 0; });

        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        if (__bwChart) {
          __bwChart.destroy();
          __bwChart = null;
        }

        var g1 = ctx.createLinearGradient(0, 0, 0, canvas.height || 256);
        g1.addColorStop(0, 'rgba(59,130,246,0.30)');
        g1.addColorStop(1, 'rgba(59,130,246,0.00)');
        var g2 = ctx.createLinearGradient(0, 0, 0, canvas.height || 256);
        g2.addColorStop(0, 'rgba(16,185,129,0.30)');
        g2.addColorStop(1, 'rgba(16,185,129,0.00)');

        function formatBytes(bytes) {
          var b = Number(bytes || 0);
          var kb = b / 1024, mb = kb / 1024, gb = mb / 1024, tb = gb / 1024;
          if (tb >= 1) return tb.toFixed(2) + ' TB';
          if (gb >= 1) return gb.toFixed(2) + ' GB';
          if (mb >= 1) return mb.toFixed(2) + ' MB';
          if (kb >= 1) return kb.toFixed(2) + ' KB';
          return b.toFixed(0) + ' B';
        }

        var isDark = document.documentElement.classList.contains('dark');
        var grid = isDark ? 'rgba(42,63,92,0.45)' : 'rgba(229,231,235,0.8)';
        var ticks = isDark ? '#9ca3af' : '#6b7280';

        __bwChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              { label: 'Download', data: download, borderColor: '#3b82f6', backgroundColor: g1, fill: true, tension: 0.35, pointRadius: 0, borderWidth: 2 },
              { label: 'Upload', data: upload, borderColor: '#10b981', backgroundColor: g2, fill: true, tension: 0.35, pointRadius: 0, borderWidth: 2 }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                labels: {
                  usePointStyle: true,
                  pointStyle: 'circle',
                  color: ticks,
                  font: { size: 14 }
                }
              },
              tooltip: {
                backgroundColor: isDark ? '#1e2d42' : '#ffffff',
                borderColor: isDark ? 'rgba(42, 63, 92, 0.42)' : '#e5e7eb',
                borderWidth: 1,
                titleColor: ticks,
                bodyColor: isDark ? '#e5e7eb' : '#152031',
                callbacks: {
                  label: function (ctx) {
                    return ctx.dataset.label + ': ' + formatBytes(ctx.parsed.y);
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { color: grid },
                ticks: { color: ticks, font: { size: 12 } },
                title: { display: true, text: 'Day of Month', color: ticks }
              },
              y: {
                grid: { color: grid },
                ticks: { color: ticks, font: { size: 12 }, callback: function (v) { return formatBytes(v); } }
              }
            }
          }
        });
      }
    </script>
  </head>
  <body class="h-full bg-[var(--np-canvas)] text-gray-100">
    <div id="np-toast-root" class="fixed right-6 top-6 z-[100] space-y-3"></div>
    <div class="flex h-screen overflow-hidden">
      {{template "sidebar.tmpl" .}}
      <div class="relative flex min-h-0 min-w-0 flex-1 flex-col">
        <div
          id="np-page-loading"
          class="np-page-loading"
          aria-busy="false"
          aria-hidden="true"
          aria-live="polite"
        >
          <div class="np-page-loading__ring" aria-hidden="true"></div>
          <span class="text-xs font-medium text-slate-400">Loading…</span>
        </div>
        <main id="np-main" class="relative flex-1 min-h-0 overflow-y-auto">
          {{.Body}}
        </main>
      </div>
    </div>
    <script>
      (function () {
        function showToast(type, message) {
          try {
            var root = document.getElementById('np-toast-root');
            if (!root) return;
            var t = (type || 'success').toLowerCase();
            var isErr  = (t === 'error' || t === 'danger' || t === 'fail' || t === 'failed');
            var isWarn = (t === 'warning' || t === 'warn');

            var cfg = isErr ? {
              border : 'rgba(185,28,28,0.45)',
              bg     : 'rgba(69,10,10,0.92)',
              accent : '#ef4444',
              title  : '#fca5a5',
              body   : 'rgba(252,165,165,0.75)',
              label  : 'Error',
              icon   : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
            } : isWarn ? {
              border : 'rgba(180,130,0,0.4)',
              bg     : 'rgba(69,45,0,0.92)',
              accent : '#f59e0b',
              title  : '#fcd34d',
              body   : 'rgba(253,211,77,0.72)',
              label  : 'Warning',
              icon   : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
            } : {
              border : 'rgba(16,185,129,0.35)',
              bg     : 'rgba(6,40,25,0.92)',
              accent : '#10b981',
              title  : '#6ee7b7',
              body   : 'rgba(110,231,183,0.70)',
              label  : 'Success',
              icon   : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
            };

            var el = document.createElement('div');
            el.style.cssText = [
              'display:flex','align-items:stretch',
              'width:360px','max-width:calc(100vw - 3rem)',
              'border-radius:10px',
              'border:1px solid ' + cfg.border,
              'background:' + cfg.bg,
              'box-shadow:0 8px 24px rgba(0,0,0,0.5)',
              'backdrop-filter:blur(12px)',
              'overflow:hidden',
              'opacity:0',
              'transform:translateX(24px)',
              'transition:opacity 220ms ease, transform 220ms ease',
            ].join(';');

            // left accent stripe
            var stripe = document.createElement('div');
            stripe.style.cssText = 'width:4px;flex-shrink:0;background:' + cfg.accent + ';border-radius:10px 0 0 10px;';

            // body wrapper
            var body = document.createElement('div');
            body.style.cssText = 'flex:1;display:flex;align-items:flex-start;gap:10px;padding:12px 14px;min-width:0;';

            // icon
            var iconWrap = document.createElement('div');
            iconWrap.style.cssText = 'flex-shrink:0;margin-top:1px;';
            iconWrap.innerHTML = cfg.icon;

            // text block
            var text = document.createElement('div');
            text.style.cssText = 'flex:1;min-width:0;';

            var titleEl = document.createElement('div');
            titleEl.style.cssText = 'font-size:0.8125rem;font-weight:600;color:' + cfg.title + ';line-height:1.3;';
            titleEl.textContent = cfg.label;

            var msgEl = document.createElement('div');
            msgEl.style.cssText = 'font-size:0.8rem;margin-top:3px;color:' + cfg.body + ';line-height:1.4;word-break:break-word;';
            msgEl.textContent = String(message || '');

            text.appendChild(titleEl);
            if (message) text.appendChild(msgEl);

            // close button
            var close = document.createElement('button');
            close.type = 'button';
            close.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
            close.style.cssText = 'flex-shrink:0;margin-top:1px;padding:2px;color:' + cfg.body + ';opacity:0.6;cursor:pointer;background:none;border:none;line-height:0;';
            close.onmouseover = function() { close.style.opacity = '1'; };
            close.onmouseout  = function() { close.style.opacity = '0.6'; };
            close.onclick = function() { dismiss(); };

            body.appendChild(iconWrap);
            body.appendChild(text);
            body.appendChild(close);

            el.appendChild(stripe);
            el.appendChild(body);
            root.appendChild(el);

            // slide in
            requestAnimationFrame(function() {
              el.style.opacity = '1';
              el.style.transform = 'translateX(0)';
            });

            function dismiss() {
              el.style.opacity = '0';
              el.style.transform = 'translateX(16px)';
              setTimeout(function() {
                try { if (el.parentNode) el.parentNode.removeChild(el); } catch(e) {}
              }, 260);
            }

            setTimeout(dismiss, 4000);
          } catch (e) {}
        }

        document.body.addEventListener('toast', function (e) {
          try {
            var d = (e && e.detail) ? e.detail : {};
            showToast(d.type || 'success', d.message || '');
          } catch (e) {}
        });

        document.body.addEventListener('usersReload', function () {
          setTimeout(function () {
            try { window.location.reload(); } catch (e) {}
          }, 600);
        });
      })();
    </script>
    {{template "partials/np_form_submit_busy.tmpl" .}}
  </body>
</html>
{{end}}

