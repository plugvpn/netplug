{{define "partials/overview_all.tmpl"}}
<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="space-y-6 lg:col-span-2">
    <div class="rounded border border-gray-200/90 bg-gray-50 shadow-sm dark:border-[rgba(148,163,184,0.055)] dark:bg-[var(--np-panel)] dark:shadow-none p-6">
      <div class="mb-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <h2 class="text-base font-normal text-gray-900 dark:text-gray-100">Connections</h2>
          <i data-lucide="info" class="h-4 w-4 text-gray-400 dark:text-gray-500" style="stroke-width:1.5"></i>
        </div>
        <a
          href="/ui/connections"
          class="rounded border border-emerald-600 px-4 py-1.5 text-sm font-normal text-emerald-600 transition-colors hover:bg-emerald-50 dark:border-emerald-500 dark:text-emerald-500 dark:hover:bg-emerald-950"
          hx-get="/ui/connections"
          hx-target="#np-main"
          hx-push-url="true"
          hx-swap="innerHTML"
        >
          View active connections
        </a>
      </div>

      <div class="mb-4">
        <div class="relative h-12 w-full overflow-hidden rounded-sm bg-gray-200/80 dark:bg-[#0a0d12]">
          {{if gt .Conn.Total 0}}
            <div class="absolute left-0 top-0 h-full bg-gradient-to-r from-emerald-400 to-emerald-500 dark:from-emerald-500 dark:to-emerald-600" style="width: {{.Conn.InUsePct}}%;"></div>
            <div class="absolute top-0 h-full bg-gradient-to-r from-amber-300 to-amber-400 dark:from-amber-500 dark:to-amber-600" style="left: {{.Conn.InUsePct}}%; width: {{.Conn.AvailablePct}}%;"></div>
          {{end}}
        </div>
      </div>

      <div class="mb-6 flex justify-between text-xs text-gray-500 dark:text-gray-400">
        <span>0</span>
        {{if gt .Conn.Total 1}}<span>{{.Conn.Mid}}</span>{{end}}
        <span>{{.Conn.Total}}</span>
      </div>

      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-2 w-2 rounded-full bg-emerald-500"></div>
            <span class="text-sm text-gray-700 dark:text-gray-300">In use (on this node)</span>
          </div>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Conn.InUse}}</span>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-2 w-2 rounded-full bg-amber-400"></div>
            <span class="text-sm text-gray-700 dark:text-gray-300">Available</span>
          </div>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Conn.Available}}</span>
        </div>
        <div class="mt-4 border-t border-gray-200 pt-3 dark:border-[rgba(148,163,184,0.06)]">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">Total</span>
            <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Conn.Total}}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded border border-gray-200/90 bg-gray-50 shadow-sm dark:border-[rgba(148,163,184,0.055)] dark:bg-[var(--np-panel)] dark:shadow-none p-6">
      <div class="mb-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <h2 class="text-base font-normal text-gray-900 dark:text-gray-100">Data Transfer</h2>
          <i data-lucide="info" class="h-4 w-4 text-gray-400 dark:text-gray-500" style="stroke-width:1.5"></i>
        </div>
      </div>

      <div class="space-y-4">
        <div class="rounded border border-gray-200/80 bg-gray-100/80 dark:border-[rgba(148,163,184,0.042)] dark:bg-[#0a0d12] p-4">
          <h3 class="mb-3 text-sm font-medium text-gray-900 dark:text-gray-100">Bandwidth Over Time (This Month)</h3>
          <div class="h-64">
            <canvas id="bandwidth-chart" data-url="/api/bandwidth/history?mode=daily" style="width:100%;height:256px;"></canvas>
          </div>
        </div>

        <div class="rounded border border-gray-200/80 bg-gray-100/80 dark:border-[rgba(148,163,184,0.042)] dark:bg-[#0a0d12] p-4">
          <div class="mb-3 flex items-center gap-2">
            <i data-lucide="hard-drive" class="h-5 w-5 text-gray-600 dark:text-gray-400" style="stroke-width:1.5"></i>
            <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100">Total Transfer (All Time)</h3>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <i data-lucide="arrow-down-circle" class="h-4 w-4 text-blue-500" style="stroke-width:1.5"></i>
                <span class="text-sm text-gray-700 dark:text-gray-300">Downloaded</span>
              </div>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">{{humanBytes .Xfer.Sent}}</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <i data-lucide="arrow-up-circle" class="h-4 w-4 text-emerald-500" style="stroke-width:1.5"></i>
                <span class="text-sm text-gray-700 dark:text-gray-300">Uploaded</span>
              </div>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">{{humanBytes .Xfer.Received}}</span>
            </div>
            <div class="mt-2 border-t border-gray-200 pt-2 dark:border-[rgba(148,163,184,0.085)]">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-gray-900 dark:text-gray-100">Total</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">{{humanBytes .Xfer.Combined}}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="lg:col-span-1">
    <div class="rounded border border-gray-200/90 bg-gray-50 shadow-sm dark:border-[rgba(148,163,184,0.055)] dark:bg-[var(--np-panel)] dark:shadow-none p-6">
      <h2 class="mb-6 text-base font-normal text-gray-900 dark:text-gray-100">Server Details</h2>
      <div class="space-y-4">
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Server address</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.ServerAddress}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Access Server version</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.Version}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Operating System</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.OSName}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">OS hostname</span>
          <span class="text-sm font-mono text-xs text-gray-900 dark:text-gray-100">{{.Sys.Hostname}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Uptime</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.UptimeHuman}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Accepting connections on</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.AcceptingOn}}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-700 dark:text-gray-300">Port</span>
          <span class="text-sm font-normal text-gray-900 dark:text-gray-100">{{.Sys.Ports}}</span>
        </div>
      </div>
    </div>
  </div>
</div>
{{end}}

