{{define "partials/qr_modal.tmpl"}}
<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm overflow-y-auto">
  <div
    class="absolute inset-0"
    hx-get="/partials/empty"
    hx-target="#modal-root"
    hx-swap="innerHTML"
  ></div>

  <div class="relative my-8 w-full max-w-2xl rounded-md border border-[rgba(148,163,184,0.06)] bg-[var(--np-panel)] shadow-none max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between border-b border-[rgba(148,163,184,0.055)] p-6">
      <div>
        <h2 class="text-xl font-semibold text-gray-100">VPN Configuration QR Code</h2>
        <p class="mt-1 text-sm text-gray-400">Scan this code or copy the configuration below</p>
      </div>
      <button
        type="button"
        class="rounded-lg p-2 text-gray-400 transition-colors hover:bg-[#1e2d42] hover:text-gray-200"
        hx-get="/partials/empty"
        hx-target="#modal-root"
        hx-swap="innerHTML"
      >
        <i data-lucide="x" class="h-5 w-5"></i>
      </button>
    </div>

    <div class="p-6">
      <div class="mb-6 w-full rounded border border-[rgba(148,163,184,0.048)] bg-[#0a0d12] p-4">
        <div class="mb-2 flex items-center gap-2 text-gray-200">
          <i data-lucide="user" class="h-4 w-4 text-gray-400" style="stroke-width:1.5"></i>
          <span class="font-medium">{{.Username}}</span>
        </div>
        <div class="text-sm text-gray-400 space-y-0.5">
          <div>Server: {{.Server}}</div>
          <div>Protocol: {{.Protocol}}</div>
          {{if .IP}}<div>IP: {{.IP}}</div>{{end}}
        </div>
      </div>

      <div class="mb-8 flex justify-center">
        <div class="rounded-md bg-white p-6 shadow-lg">
          <canvas id="np-qr-canvas" width="256" height="256"></canvas>
        </div>
      </div>

      <div class="w-full">
        <div class="mb-3 flex items-center justify-between border-b border-[rgba(148,163,184,0.055)] pb-3">
          <div>
            <h3 class="text-sm font-medium text-gray-100">Configuration File</h3>
            <p class="text-xs text-gray-400 font-mono">{{.FileName}}</p>
          </div>
          <div class="flex items-center gap-3">
            <span id="np-conf-toggle-label" class="text-sm text-gray-400">Show</span>
            <label class="relative inline-flex cursor-pointer items-center">
              <input id="np-conf-toggle" type="checkbox" class="peer sr-only" />
              <div class="peer h-6 w-11 rounded-full bg-gray-700 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-emerald-500 peer-checked:after:translate-x-full"></div>
            </label>
          </div>
        </div>

        <div id="np-conf-wrap" class="relative overflow-hidden rounded border border-[rgba(148,163,184,0.06)] bg-[#0a0d12]" style="display:none;">
          <button
            type="button"
            id="np-conf-copy"
            class="absolute right-3 top-3 z-10 rounded bg-[#1e2d42]/80 p-1.5 text-gray-300 backdrop-blur-sm transition-colors hover:text-white"
            title="Copy to clipboard"
          >
            <i data-lucide="copy" class="h-4 w-4"></i>
          </button>
          <pre class="max-h-[360px] overflow-auto p-4 text-xs text-gray-200 font-mono leading-5"><code id="np-conf-text">{{.ConfigText}}</code></pre>
        </div>
      </div>
    </div>

    <div class="border-t border-[rgba(148,163,184,0.055)] p-6">
      <button
        type="button"
        class="w-full rounded-lg border border-[rgba(148,163,184,0.09)] bg-[#152031] px-6 py-3 font-medium text-gray-200 transition-all hover:bg-[#1e2d42]"
        hx-get="/partials/empty"
        hx-target="#modal-root"
        hx-swap="innerHTML"
      >
        Close
      </button>
    </div>
  </div>
</div>

<script>
  (function () {
    try { lucide.createIcons(); } catch (e) {}

    var textEl = document.getElementById('np-conf-text');
    var confText = textEl ? (textEl.textContent || '') : '';
    var canvas = document.getElementById('np-qr-canvas');
    var QR = (window.QRCode && window.QRCode.toCanvas) ? window.QRCode : null;
    if (canvas && QR && confText) {
      try {
        QR.toCanvas(canvas, confText, { width: 256, margin: 1 }, function () {});
      } catch (e) {}
    }

    var copyBtn = document.getElementById('np-conf-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        try { navigator.clipboard.writeText(confText || ''); } catch (e) {}
      });
    }

    var toggle = document.getElementById('np-conf-toggle');
    var wrap = document.getElementById('np-conf-wrap');
    var lbl = document.getElementById('np-conf-toggle-label');
    if (toggle && wrap) {
      function apply() {
        var next = !!toggle.checked;
        wrap.style.display = next ? '' : 'none';
        if (lbl) lbl.textContent = next ? 'Hide' : 'Show';
      }
      toggle.addEventListener('change', apply);
      apply();
    }
  })();
</script>
{{end}}

