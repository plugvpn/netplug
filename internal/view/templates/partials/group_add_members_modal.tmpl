{{define "partials/group_add_members_modal.tmpl"}}
<div class="fixed inset-0 z-50 flex items-center justify-center">
  <div
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
    hx-get="/partials/empty"
    hx-target="#modal-root"
    hx-swap="innerHTML"
  ></div>

  <div class="relative flex max-h-[calc(100vh-3rem)] w-full max-w-md flex-col overflow-hidden rounded-md border border-[rgba(148,163,184,0.06)] bg-[var(--np-panel)] shadow-none">
    <div class="flex shrink-0 items-start justify-between border-b border-[rgba(148,163,184,0.055)] px-6 py-4">
      <div>
        <div class="flex items-center gap-2">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/15 text-emerald-400">
            <i data-lucide="users" class="h-5 w-5"></i>
          </div>
          <div>
            <h2 class="text-sm font-semibold text-gray-100">Add members</h2>
            <p class="text-xs text-gray-400">{{.GroupName}}</p>
          </div>
        </div>
      </div>
      <button
        type="button"
        class="rounded p-1.5 text-gray-400 hover:bg-[#1e2d42] hover:text-gray-200"
        hx-get="/partials/empty"
        hx-target="#modal-root"
        hx-swap="innerHTML"
        aria-label="Close"
      >
        <i data-lucide="x" class="h-4 w-4"></i>
      </button>
    </div>

    {{if .Candidates}}
    <form
      id="add-members-form"
      class="flex min-h-0 flex-1 flex-col overflow-hidden"
      hx-post="/ui/groups/{{.GroupID}}/members/bulk"
      hx-target="#np-main"
      hx-push-url="true"
      hx-swap="innerHTML"
    >
      <div class="shrink-0 border-b border-[rgba(148,163,184,0.055)] px-6 py-3">
        <div class="relative">
          <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500"></i>
          <input
            type="search"
            id="add-members-modal-q"
            autocomplete="off"
            placeholder="Filter by name or tunnel…"
            class="w-full rounded-lg border border-[rgba(148,163,184,0.09)] bg-[#0a0d12] py-2.5 pl-10 pr-3 text-sm text-gray-100 placeholder:text-gray-500 focus:border-emerald-600 focus:outline-none focus:ring-1 focus:ring-emerald-600"
          />
        </div>
        <label class="mt-3 flex cursor-pointer items-center gap-2 text-xs text-gray-400">
          <input
            id="add-members-select-all"
            type="checkbox"
            class="h-4 w-4 rounded border-gray-600 bg-[#0a0d12] text-emerald-500 focus:ring-emerald-500/30"
          />
          Select all (visible rows)
        </label>
      </div>

      <div class="min-h-0 flex-1 overflow-y-auto px-4 py-3" style="max-height: calc(100vh - 13.5rem); scrollbar-width: thin;">
        <div class="space-y-1.5 pb-2">
          {{range .Candidates}}
          <label
            class="add-members-row flex cursor-pointer items-center gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-emerald-500/[0.06]"
            data-filter="{{lower .Username}} {{lower .TunnelIP}}"
          >
            <input
              type="checkbox"
              name="vpn_user_id"
              value="{{.ID}}"
              class="add-members-cb h-4 w-4 shrink-0 rounded border-gray-600 bg-[#0a0d12] text-emerald-500 focus:ring-emerald-500/30"
            />
            <div class="flex min-w-0 flex-1 items-center gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[var(--np-muted)] text-xs font-semibold text-gray-300">{{initial .Username}}</span>
              <div class="min-w-0">
                <div class="truncate text-sm font-medium text-gray-100">{{.Username}}</div>
                {{if .TunnelIP}}
                  <div class="truncate font-mono text-xs text-emerald-400/90">{{.TunnelIP}}</div>
                {{else}}
                  <div class="text-xs text-gray-600">No tunnel address</div>
                {{end}}
              </div>
            </div>
          </label>
          {{end}}
        </div>
      </div>

      <div class="flex shrink-0 justify-end gap-2 border-t border-[rgba(148,163,184,0.055)] px-6 py-4">
        <button
          type="button"
          class="rounded-lg border border-[rgba(148,163,184,0.09)] px-4 py-2 text-sm font-medium text-gray-300 hover:bg-[#1e2d42]"
          hx-get="/partials/empty"
          hx-target="#modal-root"
          hx-swap="innerHTML"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-emerald-500 to-teal-500 px-5 py-2 text-sm font-semibold text-white hover:from-emerald-600 hover:to-teal-600"
        >
          <i data-lucide="corner-down-right" class="h-4 w-4"></i>
          Add selected
        </button>
      </div>
    </form>

    <script>
      (function () {
        const qEl = document.getElementById("add-members-modal-q");
        const allEl = document.getElementById("add-members-select-all");
        function norm(s) { return (s || "").toString().toLowerCase().trim(); }

        function visibleRows() {
          return Array.prototype.slice.call(document.querySelectorAll(".add-members-row")).filter(function (row) {
            return row.offsetParent !== null;
          });
        }

        function syncSelectAllState() {
          if (!allEl) return;
          const vis = visibleRows();
          if (vis.length === 0) {
            allEl.checked = false;
            allEl.indeterminate = false;
            return;
          }
          const sel = vis.filter(function (row) {
            const cb = row.querySelector(".add-members-cb");
            return cb && cb.checked;
          });
          allEl.checked = sel.length === vis.length;
          allEl.indeterminate = sel.length > 0 && sel.length < vis.length;
        }

        if (qEl) {
          qEl.addEventListener("input", function () {
            var q = norm(qEl.value);
            document.querySelectorAll(".add-members-row").forEach(function (row) {
              var hay = norm(row.getAttribute("data-filter"));
              row.style.display = !q || hay.includes(q) ? "" : "none";
              if (!(!q || hay.includes(q))) {
                var c = row.querySelector(".add-members-cb");
                if (c) c.checked = false;
              }
            });
            syncSelectAllState();
          });
        }

        if (allEl) {
          allEl.addEventListener("change", function () {
            var on = !!allEl.checked;
            visibleRows().forEach(function (row) {
              var cb = row.querySelector(".add-members-cb");
              if (cb) cb.checked = on;
            });
            syncSelectAllState();
          });
        }

        document.querySelectorAll(".add-members-cb").forEach(function (cb) {
          cb.addEventListener("change", syncSelectAllState);
        });
        syncSelectAllState();
      })();
      try { lucide.createIcons(); } catch (e) {}
    </script>

    {{else}}
    <div class="flex flex-col items-center justify-center gap-2 px-6 py-8 text-center overflow-y-auto" style="max-height: calc(100vh - 11rem);">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--np-muted)] text-gray-500">
        <i data-lucide="user-check" class="h-7 w-7"></i>
      </div>
      <p class="text-sm font-medium text-gray-300">Everyone is already in this group</p>
      <p class="max-w-[18rem] text-xs text-gray-500">Create more VPN users first, then you can assign them here.</p>
      <button
        type="button"
        class="mt-2 rounded-lg border border-[rgba(148,163,184,0.09)] px-4 py-2 text-sm text-gray-300 hover:bg-[#1e2d42]"
        hx-get="/partials/empty"
        hx-target="#modal-root"
        hx-swap="innerHTML"
      >
        Close
      </button>
    </div>
    <script>try { lucide.createIcons(); } catch (e) {}</script>
    {{end}}
  </div>
</div>
{{end}}
