{{define "servers.tmpl"}}
{{template "base.tmpl" .}}
{{end}}

{{define "servers.content"}}
<div class="h-full flex flex-col overflow-hidden">
  {{template "page_header.tmpl" .}}
  <div class="flex-1 overflow-y-auto">
    <div class="p-8">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <div class="text-base font-normal text-gray-900 dark:text-gray-100 mb-4">WireGuard</div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-gray-800">
                <th class="py-2 pr-3">Name</th>
                <th class="py-2 pr-3">Protocol</th>
                <th class="py-2 pr-3">Host</th>
                <th class="py-2 pr-3">Port</th>
                <th class="py-2 pr-3">Active</th>
              </tr>
            </thead>
            <tbody>
              {{if not .Servers}}
              <tr>
                <td class="py-3 text-gray-500 dark:text-gray-400" colspan="5">No servers found.</td>
              </tr>
              {{end}}
              {{range .Servers}}
              <tr class="border-b border-gray-100 dark:border-gray-800">
                <td class="py-2 pr-3 font-medium text-gray-900 dark:text-gray-100">{{.Name}}</td>
                <td class="py-2 pr-3 text-gray-700 dark:text-gray-300">{{.Protocol}}</td>
                <td class="py-2 pr-3 text-gray-700 dark:text-gray-300">{{.Host}}</td>
                <td class="py-2 pr-3 text-gray-700 dark:text-gray-300">{{.Port}}</td>
                <td class="py-2 pr-3 text-gray-700 dark:text-gray-300">{{if .IsActive}}yes{{else}}no{{end}}</td>
              </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
{{end}}

{{define "servers.header_right"}}{{end}}

