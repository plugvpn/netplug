{{define "groups.tmpl"}}
{{template "base.tmpl" .}}
{{end}}

{{define "groups.content"}}
<div class="h-full flex flex-col overflow-hidden">
  {{template "page_header.tmpl" .}}
  <div class="flex-1 overflow-y-auto">
    <div class="p-8 space-y-8">
      {{if .FlashMsg}}
      <div class="rounded-lg border px-4 py-3 text-sm {{if eq .FlashMsgType "error"}}border-red-500/40 bg-red-950/40 text-red-200{{else}}border-emerald-500/30 bg-emerald-950/30 text-emerald-200{{end}}">
        {{.FlashMsg}}
      </div>
      {{end}}

      <div class="rounded border border-[rgba(148,163,184,0.055)] bg-[var(--np-panel)] p-6">
        <h2 class="text-base font-semibold text-gray-100 mb-1">Create group</h2>
        <p class="text-sm text-gray-400 mb-4">Organize VPN users and optional per-group PCQ rate targets for your edge router.</p>
        <form method="post" action="/ui/groups" class="flex flex-col gap-4 sm:flex-row sm:items-end">
          <div class="flex-1">
            <label class="block text-xs font-medium text-gray-400 mb-1">Name</label>
            <input name="name" required class="w-full rounded-lg border border-[rgba(148,163,184,0.09)] bg-[var(--np-muted)] px-3 py-2 text-sm text-gray-100 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="e.g. Backend team" />
          </div>
          <div class="flex-[2]">
            <label class="block text-xs font-medium text-gray-400 mb-1">Description (optional)</label>
            <input name="description" class="w-full rounded-lg border border-[rgba(148,163,184,0.09)] bg-[var(--np-muted)] px-3 py-2 text-sm text-gray-100 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" placeholder="Short note" />
          </div>
          <button type="submit" class="rounded-lg bg-gradient-to-r from-emerald-500 to-teal-500 px-4 py-2 text-sm font-semibold text-white hover:from-emerald-600 hover:to-teal-600">
            Create
          </button>
        </form>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-gray-100 mb-2">All groups</h2>
        <p class="text-sm text-gray-400 mb-4">Open a group to manage members and PCQ (per-connection queue) presets.</p>
        <div class="overflow-hidden rounded border border-[rgba(148,163,184,0.055)]" style="background-color:var(--np-panel);">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="text-left text-gray-400 border-b border-[rgba(148,163,184,0.06)] bg-[var(--np-raised)]">
                <tr>
                  <th class="px-6 py-3 font-medium">Name</th>
                  <th class="px-6 py-3 font-medium">Members</th>
                  <th class="px-6 py-3 font-medium">PCQ preview</th>
                  <th class="px-6 py-3 font-medium text-right">Open</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[rgba(148,163,184,0.045)]">
                {{if not .Groups}}
                <tr>
                  <td class="px-6 py-6 text-gray-500" colspan="4">No groups yet. Create one above.</td>
                </tr>
                {{end}}
                {{range .Groups}}
                <tr class="hover:bg-[rgba(148,163,184,0.045)]">
                  <td class="px-6 py-4">
                    <div class="font-medium text-gray-100">{{.Name}}</div>
                    {{if .Description}}<div class="text-xs text-gray-500 mt-0.5">{{.Description}}</div>{{end}}
                  </td>
                  <td class="px-6 py-4 text-gray-300">{{.MemberCount}}</td>
                  <td class="px-6 py-4 text-gray-300">{{.PCQSummary}}</td>
                  <td class="px-6 py-4 text-right">
                    <a
                      href="/ui/groups/{{.ID}}"
                      class="inline-flex items-center gap-1 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5 text-xs font-semibold text-emerald-300 hover:bg-emerald-500/20"
                      hx-get="/ui/groups/{{.ID}}"
                      hx-target="#np-main"
                      hx-push-url="true"
                      hx-swap="innerHTML"
                    >Manage</a>
                  </td>
                </tr>
                {{end}}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{end}}

{{define "groups.header_right"}}{{end}}
