{{define "sidebar.tmpl"}}
<aside
  id="sidebar"
  data-collapsed="false"
  class="relative flex h-full flex-col border-r border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 transition-all duration-300 w-[280px]"
>
  <style>
    #sidebar[data-collapsed="true"] { width: 64px; }
    #sidebar[data-collapsed="true"] .sb-hide { display: none; }
    #sidebar[data-collapsed="true"] .sb-center { justify-content: center; }
  </style>

  <div class="relative flex h-16 items-center gap-3 border-b border-gray-200 dark:border-gray-800 px-6">
    <div class="flex items-center gap-3 min-w-0 sb-center">
      <img src="/plug-icon.png" alt="NetPlug" width="40" height="40" class="rounded-full" />
      <div class="flex flex-col min-w-0 sb-hide">
        <span class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate">NetPlug Dashboard</span>
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Version 1.0</span>
      </div>
    </div>

    <button
      onclick="toggleSidebar()"
      class="absolute -right-3 top-1/2 z-10 flex h-6 w-6 -translate-y-1/2 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 shadow-sm transition-colors hover:bg-gray-50 hover:text-gray-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-gray-300"
      title="Toggle sidebar"
      type="button"
    >
      <i data-lucide="chevron-left" class="h-4 w-4 sb-hide"></i>
      <i data-lucide="chevron-right" class="h-4 w-4" style="display:none;"></i>
    </button>
  </div>

  <nav class="flex-1 space-y-0.5 px-2 py-3">
    {{template "sidebar_item.tmpl" dict "Href" "/dashboard" "Label" "Overview" "Icon" "activity" "Active" (eq .Path "/dashboard") }}
    {{template "sidebar_item.tmpl" dict "Href" "/dashboard/connections" "Label" "Connections" "Icon" "link-2" "Active" (eq .Path "/dashboard/connections") }}
    {{template "sidebar_item.tmpl" dict "Href" "/dashboard/activity" "Label" "Activity" "Icon" "file-text" "Active" (eq .Path "/dashboard/activity") }}
    {{template "sidebar_item.tmpl" dict "Href" "/dashboard/users" "Label" "Users" "Icon" "users" "Active" (eq .Path "/dashboard/users") }}
    {{template "sidebar_item.tmpl" dict "Href" "/dashboard/wireguard" "Label" "Wireguard" "Icon" "server" "Active" (eq .Path "/dashboard/wireguard") }}
  </nav>

  <div class="border-t border-gray-200 px-2 py-3 dark:border-gray-800">
    <a
      href="/dashboard/settings"
      class="flex items-center gap-3 rounded px-3 py-2.5 text-sm font-normal transition-colors sb-center {{if eq .Path "/dashboard/settings"}}bg-emerald-50 text-emerald-900 dark:bg-emerald-900/20 dark:text-emerald-100{{else}}text-gray-700 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-gray-100{{end}}"
      title="Settings"
    >
      <i data-lucide="settings" class="h-4 w-4" style="stroke-width:1.5"></i>
      <span class="sb-hide">Settings</span>
    </a>
  </div>

  <div class="border-t border-gray-200 px-2 py-3 dark:border-gray-800">
    <div class="flex items-center justify-between gap-2 px-2 sb-center">
      <div class="flex items-center gap-2 min-w-0 flex-1 sb-hide">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 text-xs font-medium text-white">
          A
        </div>
        <div class="flex flex-col min-w-0 flex-1">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300 truncate">Admin</span>
        </div>
      </div>
      <button onclick="toggleTheme()" class="rounded p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-300" title="Toggle theme" type="button">
        <i data-lucide="sun-moon" class="h-4 w-4"></i>
      </button>
      <form method="post" action="/logout">
        <button class="rounded p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-300 shrink-0" title="Logout">
          <i data-lucide="log-out" class="h-4 w-4"></i>
        </button>
      </form>
    </div>
  </div>
</aside>
{{end}}

{{define "sidebar_item.tmpl"}}
<a
  href="{{.Href}}"
  class="flex items-center gap-3 rounded px-3 py-2.5 text-sm font-normal transition-colors sb-center {{if .Active}}bg-emerald-50 text-emerald-900 dark:bg-emerald-900/20 dark:text-emerald-100{{else}}text-gray-700 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-gray-100{{end}}"
  title="{{.Label}}"
>
  <i data-lucide="{{.Icon}}" class="h-4 w-4" style="stroke-width:1.5"></i>
  <span class="sb-hide">{{.Label}}</span>
</a>
{{end}}

