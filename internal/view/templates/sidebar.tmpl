{{define "sidebar.tmpl"}}
<aside
  id="sidebar"
  data-collapsed="false"
  class="relative flex h-full flex-col border-r border-gray-200 bg-white dark:border-[rgba(148,163,184,0.06)] dark:bg-[var(--np-panel)] transition-all duration-300 w-[280px]"
>
  <style>
    #sidebar[data-collapsed="true"] { width: 64px; }
    #sidebar[data-collapsed="true"] .sb-hide { display: none; }
    #sidebar[data-collapsed="true"] .sb-center { justify-content: center; }

    /* SPA nav active (runtime + works without Tailwind JIT for dynamic classes) */
    #sidebar a.np-spa-link.np-active {
      background-color: rgb(236 253 245);
      color: rgb(6 78 59);
    }
    html.dark #sidebar a.np-spa-link.np-active {
      background-color: rgba(16, 185, 129, 0.15);
      color: rgb(209 250 229);
    }

    /* Disabled sidebar item tooltip */
    .sb-disabled-item { position: relative; }
    .sb-disabled-item .sb-tooltip { display: none; }
  </style>

  <div class="relative flex h-16 items-center gap-3 border-b border-gray-200 dark:border-[rgba(148,163,184,0.06)] px-6">
    <div class="flex items-center gap-3 min-w-0 sb-center">
      <img src="/plug-icon.png" alt="NetPlug" width="40" height="40" class="rounded-full" />
      <div class="flex flex-col min-w-0 sb-hide">
        <span class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate">NetPlug UI</span>
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400" title="{{.GitRevision}}">Version {{.GitRevisionShort}}</span>
      </div>
    </div>

    <button
      onclick="toggleSidebar()"
      class="absolute -right-3 top-1/2 z-10 flex h-6 w-6 -translate-y-1/2 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 shadow-sm transition-colors hover:bg-gray-50 hover:text-gray-700 dark:border-[rgba(148,163,184,0.085)] dark:bg-[var(--np-muted)] dark:text-gray-400 dark:hover:bg-[#2a3f5c] dark:hover:text-gray-300"
      title="Toggle sidebar"
      type="button"
    >
      <i data-lucide="chevron-left" class="h-4 w-4 sb-hide"></i>
      <i data-lucide="chevron-right" class="h-4 w-4" style="display:none;"></i>
    </button>
  </div>

  <nav class="flex-1 space-y-0.5 px-2 py-3">
    {{template "sidebar_item.tmpl" dict "Href" "/ui" "Label" "Overview" "Icon" "layout-dashboard" "Active" (eq .Path "/ui") }}
    {{template "sidebar_item.tmpl" dict "Href" "/ui/connections" "Label" "Connections" "Icon" "link-2" "Active" (eq .Path "/ui/connections") }}
    {{template "sidebar_item.tmpl" dict "Href" "/ui/users" "Label" "Users" "Icon" "users" "Active" (eq .Path "/ui/users") }}
    {{template "sidebar_item.tmpl" dict "Href" "/ui/groups" "Label" "Groups" "Icon" "users-round" "Active" (or (eq .Path "/ui/groups") (hasPrefix .Path "/ui/groups/")) }}
    {{if .PCQDisabled}}
    {{template "sidebar_item_disabled.tmpl" dict "Label" "Queues" "Icon" "sliders-horizontal" "Tooltip" "Queues is disabled"}}
    {{else}}
    {{template "sidebar_item.tmpl" dict "Href" "/ui/queues" "Label" "Queues" "Icon" "sliders-horizontal" "Active" (or (eq .Path "/ui/queues") (hasPrefix .Path "/ui/queues/")) }}
    {{end}}
    {{template "sidebar_item.tmpl" dict "Href" "/ui/wireguard" "Label" "Wireguard" "Icon" "server" "Active" (eq .Path "/ui/wireguard") }}
  </nav>

  <div class="border-t border-gray-200 px-2 py-3 dark:border-[rgba(148,163,184,0.06)]">
    <a
      href="/ui/settings"
      class="np-spa-link flex items-center gap-3 rounded px-3 py-2.5 text-sm font-normal transition-colors sb-center text-gray-700 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-[var(--np-muted)] dark:hover:text-gray-100 {{if eq .Path "/ui/settings"}}np-active{{end}}"
      hx-get="/ui/settings"
      hx-target="#np-main"
      hx-push-url="true"
      hx-swap="innerHTML"
      title="Settings"
    >
      <i data-lucide="settings" class="h-4 w-4" style="stroke-width:1.5"></i>
      <span class="sb-hide">Settings</span>
    </a>
  </div>

  <div class="border-t border-gray-200 px-2 py-3 dark:border-[rgba(148,163,184,0.06)]">
    <div class="flex items-center justify-between gap-2 px-2 sb-center">
      <div class="flex items-center gap-2 min-w-0 flex-1 sb-hide">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 text-xs font-medium text-white">
          A
        </div>
        <div class="flex flex-col min-w-0 flex-1">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300 truncate">Admin</span>
        </div>
      </div>
      <form method="post" action="/logout">
        <button class="rounded p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-[var(--np-muted)] dark:hover:text-gray-300 shrink-0" title="Logout">
          <i data-lucide="log-out" class="h-4 w-4"></i>
        </button>
      </form>
    </div>
  </div>
</aside>
<script>
  (function () {
    // Create a single global tooltip node directly on <body> to escape all stacking contexts.
    var globalTip = document.createElement('div');
    globalTip.style.cssText = [
      'position:fixed',
      'z-index:999999',
      'display:none',
      'white-space:nowrap',
      'background:#1e293b',
      'color:#f8b94b',
      'font-size:0.72rem',
      'font-weight:500',
      'padding:5px 10px',
      'border-radius:6px',
      'border:1px solid rgba(251,191,36,0.25)',
      'pointer-events:none',
      'box-shadow:0 4px 16px rgba(0,0,0,0.5)',
    ].join(';');
    document.body.appendChild(globalTip);

    document.querySelectorAll('.sb-disabled-item').forEach(function (item) {
      var src = item.querySelector('.sb-tooltip');
      var text = src ? src.textContent.trim() : '';
      if (!text) return;

      item.addEventListener('mouseenter', function () {
        globalTip.textContent = text;
        globalTip.style.display = 'block';
        var r = item.getBoundingClientRect();
        globalTip.style.top  = Math.round(r.top + r.height / 2 - globalTip.offsetHeight / 2) + 'px';
        globalTip.style.left = Math.round(r.right + 10) + 'px';
      });
      item.addEventListener('mouseleave', function () {
        globalTip.style.display = 'none';
      });
    });
  })();
</script>
{{end}}

{{define "sidebar_item.tmpl"}}
<a
  href="{{.Href}}"
  class="np-spa-link flex items-center gap-3 rounded px-3 py-2.5 text-sm font-normal transition-colors sb-center text-gray-700 hover:bg-gray-50 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-[var(--np-muted)] dark:hover:text-gray-100 {{if .Active}}np-active{{end}}"
  hx-get="{{.Href}}"
  hx-target="#np-main"
  hx-push-url="true"
  hx-swap="innerHTML"
  title="{{.Label}}"
>
  <i data-lucide="{{.Icon}}" class="h-4 w-4" style="stroke-width:1.5"></i>
  <span class="sb-hide">{{.Label}}</span>
</a>
{{end}}

{{define "sidebar_item_disabled.tmpl"}}
<div
  class="sb-disabled-item flex items-center gap-3 rounded px-3 py-2.5 text-sm font-normal sb-center cursor-not-allowed opacity-40 select-none"
  style="color: rgb(156 163 175);"
>
  <i data-lucide="{{.Icon}}" class="h-4 w-4 shrink-0" style="stroke-width:1.5"></i>
  <span class="sb-hide flex-1">{{.Label}}</span>
  <span class="sb-tooltip">{{.Tooltip}}</span>
</div>
{{end}}
