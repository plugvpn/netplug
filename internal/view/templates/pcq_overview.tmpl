{{define "pcq_overview.tmpl"}}
{{template "base.tmpl" .}}
{{end}}

{{define "pcq_overview.content"}}
<div class="h-full flex flex-col overflow-hidden">
  {{template "page_header.tmpl" .}}
  <div class="flex-1 overflow-y-auto">
    <div class="p-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Queues</h2>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
            Per-group traffic queues: rate limits merged per tunnel IPv4 and applied with Linux <code class="text-xs text-gray-500 dark:text-gray-500">tc</code> on the WireGuard interface.
            Create presets from <strong class="font-medium text-gray-500 dark:text-gray-400">Add queue</strong> for groups that don&rsquo;t have one yet.
          </p>
        </div>
        <a
          href="/ui/groups"
          class="flex items-center gap-2 rounded-lg bg-gradient-to-r from-emerald-500 to-teal-500 px-4 py-2.5 text-sm font-semibold text-white transition-all hover:from-emerald-600 hover:to-teal-600"
          hx-get="/ui/groups"
          hx-target="#np-main"
          hx-push-url="true"
          hx-swap="innerHTML"
        >
          <i data-lucide="users" class="h-4 w-4"></i>
          Manage groups
        </a>
      </div>

      {{if .PCQDisabled}}
      <div class="mb-6 flex items-start gap-3 rounded-lg border border-amber-500/30 bg-amber-950/30 px-4 py-4 text-sm text-amber-200">
        <i data-lucide="alert-triangle" class="mt-0.5 h-4 w-4 shrink-0 text-amber-400" style="stroke-width:2"></i>
        <div>
          <p class="font-semibold text-amber-300">Queue shaping is disabled</p>
          <p class="mt-0.5 text-amber-300/70">
            <code class="text-xs font-mono text-amber-400">NETPLUG_PCQ_DISABLE=1</code> is set.
            No <code class="text-xs font-mono text-amber-400">tc</code> rules are applied to the WireGuard interface.
            Presets are saved and can be configured, but shaping is inactive until the flag is removed.
          </p>
        </div>
      </div>
      {{end}}

      {{if .FlashMsg}}
      <div class="mb-6 rounded-lg border px-4 py-3 text-sm {{if eq .FlashMsgType "error"}}border-red-500/40 bg-red-950/40 text-red-200{{else}}border-emerald-500/30 bg-emerald-950/30 text-emerald-200{{end}}">
        {{.FlashMsg}}
      </div>
      {{end}}

      {{if or .QueuePresets .GroupsSansQueue}}
      <div class="mb-6">
        <div class="relative">
          <i data-lucide="search" class="absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
          <input
            id="queues-search"
            type="text"
            placeholder="Search queue presets or groups without a preset…"
            class="w-full rounded-lg border border-gray-300 bg-white py-3 pl-10 pr-4 text-sm text-gray-900 placeholder-gray-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 dark:border-[rgba(148,163,184,0.09)] dark:bg-[var(--np-muted)] dark:text-gray-100 dark:placeholder-gray-500"
          />
        </div>
      </div>
      {{end}}

      <style>
        tr.queues-row, tr.pending-queue-row {
          transition: background-color 0.15s ease-out;
        }
        tr.queues-row:nth-child(odd), tr.pending-queue-row:nth-child(odd) {
          background-color: var(--np-panel);
        }
        tr.queues-row:nth-child(even), tr.pending-queue-row:nth-child(even) {
          background-color: #0a0d12;
        }
        tr.queues-row:hover, tr.pending-queue-row:hover {
          background-color: rgba(148, 163, 184, 0.065) !important;
        }
      </style>

      <div>
      <div class="overflow-hidden rounded border border-[rgba(148,163,184,0.055)]" style="background-color:var(--np-panel);">
        <div class="border-b border-[rgba(148,163,184,0.06)] bg-gradient-to-r from-[var(--np-raised)] to-[var(--np-panel)] p-6">
          <h3 class="text-base font-normal text-white">Queue presets ({{len .QueuePresets}})</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">
            Saved limits for groups. Clearing a preset via the detail page removes the group from this list until you add limits again.
          </p>
        </div>
        <div class="overflow-x-auto" style="background-color:var(--np-panel); scrollbar-width:thin; scrollbar-color:#374151 var(--np-panel);">
          <table class="w-full" style="background-color:var(--np-panel);">
            <thead style="background-color:var(--np-raised);">
              <tr class="border-b border-[rgba(148,163,184,0.07)] text-left text-sm font-medium text-gray-300 dark:text-gray-400">
                <th class="px-6 py-3">Group</th>
                <th class="px-6 py-3">Members</th>
                <th class="px-6 py-3">Caps</th>
                <th class="px-6 py-3">Classifier</th>
                <th class="px-6 py-3">Status</th>
                <th class="px-6 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[rgba(148,163,184,0.045)]" style="background-color:var(--np-panel);">
              {{if not .QueuePresets}}
              <tr>
                <td class="px-6 py-6 text-sm text-gray-500 dark:text-gray-500" colspan="6">
                  {{if .GroupsSansQueue}}
                    No queue presets yet. Add one for a group below, or visit a group via <strong class="font-medium text-gray-400">Add queue</strong>.
                  {{else}}
                    No groups yet. Create a group first under
                    <a href="/ui/groups" class="text-emerald-400 hover:text-emerald-300" hx-get="/ui/groups" hx-target="#np-main" hx-push-url="true" hx-swap="innerHTML">Groups</a>.
                  {{end}}
                </td>
              </tr>
              {{end}}
              {{range .QueuePresets}}
              <tr
                class="queues-row"
                data-group="{{lower .Name}}"
                data-caps="{{lower .PCQSummary}}"
                data-clf="{{lower .Classifier}}"
              >
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-700 dark:bg-[var(--np-muted)]">
                      <i data-lucide="gauge" class="h-5 w-5 text-gray-300 dark:text-gray-400"></i>
                    </div>
                    <div>
                      <p class="font-medium text-gray-100 dark:text-gray-100">{{.Name}}</p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm text-gray-300 dark:text-gray-400">{{.Members}}</span>
                </td>
                <td class="px-6 py-4">
                  {{if ne .PCQSummary "—"}}
                    <span class="font-mono text-sm font-medium text-emerald-400 dark:text-emerald-400">{{.PCQSummary}}</span>
                  {{else}}
                    <span class="text-sm text-gray-500 dark:text-gray-500">Not set</span>
                  {{end}}
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm font-mono text-gray-400 dark:text-gray-400">{{.Classifier}}</span>
                </td>
                <td class="px-6 py-4">
                  {{if .IsDisabled}}
                    <span class="inline-flex items-center gap-2 rounded-full border border-red-700/60 bg-red-950/60 px-3 py-1 text-xs font-semibold text-red-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                      Limits Off
                    </span>
                  {{else if .HasLimits}}
                    <span class="inline-flex items-center gap-2 rounded-full border border-emerald-700 bg-emerald-950 px-3 py-1 text-xs font-semibold text-emerald-400 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Limits on
                    </span>
                  {{else}}
                    <span class="inline-flex items-center gap-2 rounded-full border border-gray-600 bg-gray-800 px-3 py-1 text-xs font-semibold text-gray-400 dark:border-[rgba(148,163,184,0.085)] dark:bg-[var(--np-muted)] dark:text-gray-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-gray-400"></span>
                      No caps
                    </span>
                  {{end}}
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <form method="post" action="/ui/queues/{{.GroupID}}/toggle">
                      <input type="hidden" name="redirect" value="/ui/queues" />
                      {{if .IsDisabled}}
                      <button type="submit" class="rounded-lg bg-emerald-500/15 p-2 text-emerald-400 transition-colors hover:bg-emerald-500/25 hover:text-emerald-300" title="Enable queue">
                        <i data-lucide="play" class="h-4 w-4"></i>
                      </button>
                      {{else}}
                      <button type="submit" class="rounded-lg bg-amber-500/10 p-2 text-amber-400 transition-colors hover:bg-amber-500/20 hover:text-amber-300" title="Disable queue">
                        <i data-lucide="pause" class="h-4 w-4"></i>
                      </button>
                      {{end}}
                    </form>
                    <a
                      href="/ui/queues/{{.GroupID}}"
                      class="rounded-lg bg-emerald-500/15 p-2 text-emerald-400 transition-colors hover:bg-emerald-500/25 hover:text-emerald-300"
                      title="Edit queue preset"
                      hx-get="/ui/queues/{{.GroupID}}"
                      hx-target="#np-main"
                      hx-push-url="true"
                      hx-swap="innerHTML"
                    >
                      <i data-lucide="sliders-horizontal" class="h-4 w-4"></i>
                    </a>
                    <a
                      href="/ui/groups/{{.GroupID}}"
                      class="rounded-lg bg-[var(--np-muted)] p-2 text-gray-400 transition-colors hover:bg-[rgba(148,163,184,0.08)] hover:text-gray-300"
                      title="Group members"
                      hx-get="/ui/groups/{{.GroupID}}"
                      hx-target="#np-main"
                      hx-push-url="true"
                      hx-swap="innerHTML"
                    >
                      <i data-lucide="users" class="h-4 w-4"></i>
                    </a>
                  </div>
                </td>
              </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </div>

      {{if .GroupsSansQueue}}
      <div class="overflow-hidden rounded border border-[rgba(148,163,184,0.055)]" style="margin-top:2rem; background-color:var(--np-panel);">
        <div class="border-b border-[rgba(148,163,184,0.06)] bg-gradient-to-r from-[var(--np-raised)] to-[var(--np-panel)] p-6">
          <h3 class="text-base font-normal text-white">Groups without a queue preset ({{len .GroupsSansQueue}})</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">
            New groups do not appear in queue limits until you add a preset here.
          </p>
        </div>
        <div class="overflow-x-auto" style="background-color:var(--np-panel); scrollbar-width:thin; scrollbar-color:#374151 var(--np-panel);">
          <table class="w-full" style="background-color:var(--np-panel);">
            <thead style="background-color:var(--np-raised);">
              <tr class="border-b border-[rgba(148,163,184,0.07)] text-left text-sm font-medium text-gray-300 dark:text-gray-400">
                <th class="px-6 py-3">Group</th>
                <th class="px-6 py-3">Members</th>
                <th class="px-6 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[rgba(148,163,184,0.045)]" style="background-color:var(--np-panel);">
              {{if not .GroupsSansQueue}}
              <tr>
                <td class="px-6 py-6 text-sm text-gray-500 dark:text-gray-500" colspan="3">
                  Every group either has a saved queue preset above, or there are no groups yet.
                </td>
              </tr>
              {{end}}
              {{range .GroupsSansQueue}}
              <tr
                class="pending-queue-row"
                data-group="{{lower .Name}}"
                data-caps=""
                data-clf=""
              >
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gray-700 dark:bg-[var(--np-muted)]">
                      <i data-lucide="folder" class="h-5 w-5 text-gray-300 dark:text-gray-400"></i>
                    </div>
                    <span class="font-medium text-gray-100">{{.Name}}</span>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-300">{{.Members}}</td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a
                      href="/ui/queues/{{.GroupID}}"
                      class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-emerald-500 to-teal-500 px-4 py-2 text-sm font-semibold text-white transition-all hover:from-emerald-600 hover:to-teal-600"
                      hx-get="/ui/queues/{{.GroupID}}"
                      hx-target="#np-main"
                      hx-push-url="true"
                      hx-swap="innerHTML"
                    >
                      <i data-lucide="plus" class="h-4 w-4"></i>
                      Add queue
                    </a>
                    <a
                      href="/ui/groups/{{.GroupID}}"
                      class="rounded-lg bg-[var(--np-muted)] p-2 text-gray-400 transition-colors hover:bg-[rgba(148,163,184,0.08)] hover:text-gray-300"
                      title="Group members"
                      hx-get="/ui/groups/{{.GroupID}}"
                      hx-target="#np-main"
                      hx-push-url="true"
                      hx-swap="innerHTML"
                    >
                      <i data-lucide="users" class="h-4 w-4"></i>
                    </a>
                  </div>
                </td>
              </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </div>
      {{end}}
      </div>
    </div>
  </div>
  <div id="modal-root"></div>
</div>
<script>
  (function () {
    const input = document.getElementById('queues-search');
    if (!input) return;

    function norm(s) {
      return (s || '').toString().toLowerCase().trim();
    }

    input.addEventListener('input', function () {
      const q = norm(input.value);
      const rows = document.querySelectorAll('tr.queues-row, tr.pending-queue-row');
      rows.forEach(function (row) {
        const g = norm(row.getAttribute('data-group'));
        const caps = norm(row.getAttribute('data-caps'));
        const c = norm(row.getAttribute('data-clf'));
        const ok = !q || g.includes(q) || caps.includes(q) || c.includes(q);
        row.style.display = ok ? '' : 'none';
      });
    });
  })();
</script>
{{end}}

{{define "pcq_overview.header_right"}}{{end}}
